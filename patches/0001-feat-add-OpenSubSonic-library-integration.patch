+
+void OpenSubSonicFeature::slotArtistsLoaded(const QJsonArray& artists) {
+    m_cachedArtists = artists;
+    populateSidebarModel();
+}
+
+void OpenSubSonicFeature::slotArtistLoaded(const QJsonObject& artist) {
+    const QString artistId = artist.value(QStringLiteral("id")).toString();
+    if (m_activeViewType != QStringLiteral("artist") ||
+            m_activeViewId != artistId) {
+        return;
+    }
+    m_pendingArtistId = artistId;
+
+    const QJsonArray albums = artist.value(QStringLiteral("album")).toArray();
+    if (albums.isEmpty()) {
+        return;
+    }
+
+    m_pendingArtistAlbumLoads = albums.size();
+
+    {
+        ScopedTransaction transaction(m_database);
+        clearTable(m_database, kTableLibrary);
+        transaction.commit();
+    }
+
+    for (const QJsonValue& albumVal : albums) {
+        const QJsonObject albumObj = albumVal.toObject();
+        const QString albumId = albumObj.value(QStringLiteral("id")).toString();
+        m_pApiClient->getAlbum(albumId);
+    }
+}
+
+void OpenSubSonicFeature::insertTracksFromSongs(
+        const QJsonArray& songs, bool clearFirst) {
+    ScopedTransaction transaction(m_database);
+
+    if (clearFirst) {
+        clearTable(m_database, kTableLibrary);
+    }
+
+    QSqlQuery query(m_database);
+    query.prepare(QStringLiteral(
+            "INSERT INTO opensubsonic_library "
+            "(artist, title, album, album_artist, year, genre, tracknumber, "
+            "location, comment, duration, bitrate, bpm, key, rating) "
+            "VALUES (:artist, :title, :album, :album_artist, :year, :genre, "
+            ":tracknumber, :location, :comment, :duration, :bitrate, :bpm, "
+            ":key, :rating)"));
+
+    for (const QJsonValue& songVal : songs) {
+        const QJsonObject song = songVal.toObject();
+        const QString songId = song.value(QStringLiteral("id")).toString();
+        query.bindValue(QStringLiteral(":artist"),
+                song.value(QStringLiteral("artist")).toString());
+        query.bindValue(QStringLiteral(":title"),
+                song.value(QStringLiteral("title")).toString());
+        query.bindValue(QStringLiteral(":album"),
+                song.value(QStringLiteral("album")).toString());
+        query.bindValue(QStringLiteral(":album_artist"),
+                song.value(QStringLiteral("albumArtist")).toString());
+        query.bindValue(QStringLiteral(":year"),
+                song.value(QStringLiteral("year")).toInt());
+        query.bindValue(QStringLiteral(":genre"),
+                song.value(QStringLiteral("genre")).toString());
+        query.bindValue(QStringLiteral(":tracknumber"),
+                QString::number(song.value(QStringLiteral("track")).toInt()));
+        const QString suffix = song.value(QStringLiteral("suffix")).toString(
+                QStringLiteral("mp3"));
+        query.bindValue(QStringLiteral(":location"),
+                cachePath(songId, suffix));
+        query.bindValue(QStringLiteral(":comment"), QString());
+        query.bindValue(QStringLiteral(":duration"),
+                song.value(QStringLiteral("duration")).toInt());
+        query.bindValue(QStringLiteral(":bitrate"),
+                QString::number(song.value(QStringLiteral("bitRate")).toInt()));
+        query.bindValue(QStringLiteral(":bpm"),
+                song.value(QStringLiteral("bpm")).toDouble());
+        query.bindValue(QStringLiteral(":key"), QString());
+        query.bindValue(QStringLiteral(":rating"),
+                song.value(QStringLiteral("userRating")).toInt());
+
+        if (!query.exec()) {
+            kLogger.warning() << "Failed to insert track:" << query.lastError();
+        }
+    }
+    transaction.commit();
+}
+
+void OpenSubSonicFeature::slotAlbumLoaded(const QJsonObject& album) {
+    const QJsonArray songs = album.value(QStringLiteral("song")).toArray();
+
+    if (m_pendingArtistAlbumLoads > 0) {
+        if (m_activeViewType != QStringLiteral("artist") ||
+                m_activeViewId != m_pendingArtistId) {
+            return;
+        }
+        insertTracksFromSongs(songs, false);
+        m_pendingArtistAlbumLoads--;
+
+        if (m_pendingArtistAlbumLoads == 0) {
+            m_trackSource->buildIndex();
+            m_pTrackModel->select();
+            emit showTrackModel(m_pTrackModel);
+        }
+    } else {
+        const QString albumId = album.value(QStringLiteral("id")).toString();
+        if (m_activeViewType != QStringLiteral("album") ||
+                m_activeViewId != albumId) {
+            return;
+        }
+        insertTracksFromSongs(songs, true);
+        m_trackSource->buildIndex();
+        m_pTrackModel->select();
+        emit showTrackModel(m_pTrackModel);
+    }
+}
+
+void OpenSubSonicFeature::slotPlaylistsLoaded(const QJsonArray& playlists) {
+    m_cachedPlaylists = playlists;
+    populateSidebarModel();
+}
+
+void OpenSubSonicFeature::slotPlaylistLoaded(const QJsonObject& playlist) {
+    const QString playlistIdStr = playlist.value(QStringLiteral("id")).toString();
+    if (m_activeViewType != QStringLiteral("playlist") ||
+            m_activeViewId != playlistIdStr) {
+        return;
+    }
+
+    const QString playlistName = playlist.value(QStringLiteral("name")).toString();
+    const QJsonArray entries = playlist.value(QStringLiteral("entry")).toArray();
+
+    ScopedTransaction transaction(m_database);
+
+    clearTable(m_database, kTableLibrary);
+    clearTable(m_database, kTablePlaylists);
+    clearTable(m_database, kTablePlaylistTracks);
+
+    QSqlQuery playlistQuery(m_database);
+    playlistQuery.prepare(QStringLiteral(
+            "INSERT OR REPLACE INTO opensubsonic_playlists (id, name) VALUES (:id, :name)"));
+    playlistQuery.bindValue(QStringLiteral(":id"), 1);
+    playlistQuery.bindValue(QStringLiteral(":name"), playlistName);
+    if (!playlistQuery.exec()) {
+        kLogger.warning() << "Failed to insert playlist:" << playlistQuery.lastError();
+    }
+
+    QSqlQuery trackQuery(m_database);
+    trackQuery.prepare(QStringLiteral(
+            "INSERT INTO opensubsonic_library "
+            "(artist, title, album, album_artist, year, genre, tracknumber, "
+            "location, comment, duration, bitrate, bpm, key, rating) "
+            "VALUES (:artist, :title, :album, :album_artist, :year, :genre, "
+            ":tracknumber, :location, :comment, :duration, :bitrate, :bpm, "
+            ":key, :rating)"));
+
+    int position = 0;
+    for (const QJsonValue& entryVal : entries) {
+        const QJsonObject entry = entryVal.toObject();
+        const QString songId = entry.value(QStringLiteral("id")).toString();
+        trackQuery.bindValue(QStringLiteral(":artist"),
+                entry.value(QStringLiteral("artist")).toString());
+        trackQuery.bindValue(QStringLiteral(":title"),
+                entry.value(QStringLiteral("title")).toString());
+        trackQuery.bindValue(QStringLiteral(":album"),
+                entry.value(QStringLiteral("album")).toString());
+        trackQuery.bindValue(QStringLiteral(":album_artist"),
+                entry.value(QStringLiteral("albumArtist")).toString());
+        trackQuery.bindValue(QStringLiteral(":year"),
+                entry.value(QStringLiteral("year")).toInt());
+        trackQuery.bindValue(QStringLiteral(":genre"),
+                entry.value(QStringLiteral("genre")).toString());
+        trackQuery.bindValue(QStringLiteral(":tracknumber"),
+                QString::number(entry.value(QStringLiteral("track")).toInt()));
+        const QString suffix = entry.value(QStringLiteral("suffix")).toString(
+                QStringLiteral("mp3"));
+        trackQuery.bindValue(QStringLiteral(":location"),
+                cachePath(songId, suffix));
+        trackQuery.bindValue(QStringLiteral(":comment"), QString());
+        trackQuery.bindValue(QStringLiteral(":duration"),
+                entry.value(QStringLiteral("duration")).toInt());
+        trackQuery.bindValue(QStringLiteral(":bitrate"),
+                QString::number(entry.value(QStringLiteral("bitRate")).toInt()));
+        trackQuery.bindValue(QStringLiteral(":bpm"),
+                entry.value(QStringLiteral("bpm")).toDouble());
+        trackQuery.bindValue(QStringLiteral(":key"), QString());
+        trackQuery.bindValue(QStringLiteral(":rating"),
+                entry.value(QStringLiteral("userRating")).toInt());
+
+        if (!trackQuery.exec()) {
+            kLogger.warning() << "Failed to insert playlist track:"
+                              << trackQuery.lastError();
+            continue;
+        }
+
+        const int trackId = trackQuery.lastInsertId().toInt();
+        QSqlQuery linkQuery(m_database);
+        linkQuery.prepare(QStringLiteral(
+                "INSERT INTO opensubsonic_playlist_tracks "
+                "(playlist_id, track_id, position) VALUES (:playlist_id, :track_id, :position)"));
+        linkQuery.bindValue(QStringLiteral(":playlist_id"), 1);
+        linkQuery.bindValue(QStringLiteral(":track_id"), trackId);
+        linkQuery.bindValue(QStringLiteral(":position"), position++);
+        if (!linkQuery.exec()) {
+            kLogger.warning() << "Failed to insert playlist link:"
+                              << linkQuery.lastError();
+        }
+    }
+    transaction.commit();
+
+    m_trackSource->buildIndex();
+    m_pPlaylistModel->setPlaylistById(1);
+    emit showTrackModel(m_pPlaylistModel);
+}
+
+void OpenSubSonicFeature::populateSidebarModel() {
+    clearLastRightClickedIndex();
+
+    auto pRootItem = TreeItem::newRoot(this);
+
+    if (!m_cachedArtists.isEmpty()) {
+        TreeItem* pArtistsItem = pRootItem->appendChild(
+                tr("Artists"), QVariant(QStringLiteral("artists")));
+        buildArtistTree(pArtistsItem, m_cachedArtists);
+    }
+
+    if (!m_cachedPlaylists.isEmpty()) {
+        TreeItem* pPlaylistsItem = pRootItem->appendChild(
+                tr("Playlists"), QVariant(QStringLiteral("playlists")));
+        buildPlaylistTree(pPlaylistsItem, m_cachedPlaylists);
+    }
+
+    m_pSidebarModel->setRootItem(std::move(pRootItem));
+    emit featureLoadingFinished(this);
+}
+
+void OpenSubSonicFeature::buildArtistTree(
+        TreeItem* pParent, const QJsonArray& artistIndex) {
+    for (const QJsonValue& indexVal : artistIndex) {
+        const QJsonObject indexObj = indexVal.toObject();
+        const QJsonArray artists = indexObj.value(QStringLiteral("artist")).toArray();
+        for (const QJsonValue& artistVal : artists) {
+            const QJsonObject artist = artistVal.toObject();
+            const QString name = artist.value(QStringLiteral("name")).toString();
+            const QString id = artist.value(QStringLiteral("id")).toString();
+            pParent->appendChild(name, QVariant(QStringLiteral("artist:") + id));
+        }
+    }
+}
+
+void OpenSubSonicFeature::buildPlaylistTree(
+        TreeItem* pParent, const QJsonArray& playlists) {
+    for (const QJsonValue& playlistVal : playlists) {
+        const QJsonObject playlist = playlistVal.toObject();
+        const QString name = playlist.value(QStringLiteral("name")).toString();
+        const QString id = playlist.value(QStringLiteral("id")).toString();
+        pParent->appendChild(name, QVariant(QStringLiteral("playlist:") + id));
+    }
+}
+
+std::unique_ptr<BaseSqlTableModel>
+OpenSubSonicFeature::createPlaylistModelForPlaylist(const QVariant& data) {
+    Q_UNUSED(data);
+    return nullptr;
+}
+
+QString OpenSubSonicFeature::cachePath(
+        const QString& songId, const QString& suffix) const {
+    const QString cacheDir = QStandardPaths::writableLocation(QStandardPaths::CacheLocation) +
+            QStringLiteral("/opensubsonic");
+    return cacheDir + QStringLiteral("/") + songId + QStringLiteral(".") + suffix;
+}
