diff --git a/src/library/opensubsonic/opensubsonicapiclient.cpp b/src/library/opensubsonic/opensubsonicapiclient.cpp
new file mode 100644
index 0000000..22f65c6
--- /dev/null
+++ b/src/library/opensubsonic/opensubsonicapiclient.cpp
@@ -0,0 +1,282 @@
+#include "library/opensubsonic/opensubsonicapiclient.h"
+
+#include <QCryptographicHash>
+#include <QJsonDocument>
+#include <QJsonObject>
+#include <QNetworkReply>
+#include <QRandomGenerator>
+
+#include "moc_opensubsonicapiclient.cpp"
+#include "util/logger.h"
+
+namespace {
+const mixxx::Logger kLogger("OpenSubSonicApiClient");
+
+QString generateRandomSalt(int length = 16) {
+    static const char alphanum[] =
+            "0123456789"
+            "abcdefghijklmnopqrstuvwxyz";
+    QString salt;
+    salt.reserve(length);
+    for (int i = 0; i < length; ++i) {
+        salt.append(QLatin1Char(
+                alphanum[QRandomGenerator::global()->bounded(
+                        static_cast<int>(sizeof(alphanum) - 1))]));
+    }
+    return salt;
+}
+} // namespace
+
+namespace mixxx {
+namespace library {
+namespace opensubsonic {
+
+OpenSubSonicApiClient::OpenSubSonicApiClient(
+        QNetworkAccessManager* pNetworkManager,
+        const ServerConfig& config,
+        QObject* parent)
+        : QObject(parent),
+          m_pNetworkManager(pNetworkManager),
+          m_config(config) {
+}
+
+void OpenSubSonicApiClient::setServerConfig(const ServerConfig& config) {
+    m_config = config;
+}
+
+QString OpenSubSonicApiClient::normalizedPath(const QUrl& serverUrl) {
+    QString path = serverUrl.path();
+    while (path.endsWith(QLatin1Char('/'))) {
+        path.chop(1);
+    }
+    if (path.endsWith(QStringLiteral("/rest"))) {
+        path.chop(5);
+    }
+    return path;
+}
+
+QPair<QString, QString> OpenSubSonicApiClient::generateAuthToken() const {
+    const QString salt = generateRandomSalt();
+    const QByteArray data = (m_config.password + salt).toUtf8();
+    const QString token = QString::fromLatin1(
+            QCryptographicHash::hash(data, QCryptographicHash::Md5).toHex());
+    return {token, salt};
+}
+
+QPair<QString, QString> OpenSubSonicApiClient::generateDeterministicAuthToken() const {
+    QUrl normalized = m_config.serverUrl;
+    normalized.setPath(normalizedPath(m_config.serverUrl));
+    normalized.setQuery(QString());
+    normalized.setFragment(QString());
+    const QString salt = QString::fromLatin1(
+            QCryptographicHash::hash(
+                    (m_config.username + normalized.toString()).toUtf8(),
+                    QCryptographicHash::Sha256)
+                    .toHex()
+                    .left(16));
+    const QByteArray data = (m_config.password + salt).toUtf8();
+    const QString token = QString::fromLatin1(
+            QCryptographicHash::hash(data, QCryptographicHash::Md5).toHex());
+    return {token, salt};
+}
+
+QUrlQuery OpenSubSonicApiClient::buildAuthQuery() const {
+    QUrlQuery query;
+    query.addQueryItem(QStringLiteral("u"), m_config.username);
+    query.addQueryItem(QStringLiteral("v"), m_config.apiVersion);
+    query.addQueryItem(QStringLiteral("c"), m_config.clientName);
+    query.addQueryItem(QStringLiteral("f"), QStringLiteral("json"));
+
+    const auto [token, salt] = generateAuthToken();
+    query.addQueryItem(QStringLiteral("t"), token);
+    query.addQueryItem(QStringLiteral("s"), salt);
+
+    return query;
+}
+
+QUrl OpenSubSonicApiClient::buildRequestUrl(const QString& endpoint) const {
+    QUrl url = m_config.serverUrl;
+    QString path = normalizedPath(url);
+    path.append(QStringLiteral("/rest/"));
+    path.append(endpoint);
+    url.setPath(path);
+    url.setQuery(buildAuthQuery());
+    return url;
+}
+
+void OpenSubSonicApiClient::sendRequest(
+        const QString& endpoint, const QUrlQuery& extraParams) {
+    QUrl url = buildRequestUrl(endpoint);
+
+    if (!extraParams.isEmpty()) {
+        QUrlQuery query(url.query());
+        for (const auto& item : extraParams.queryItems()) {
+            query.addQueryItem(item.first, item.second);
+        }
+        url.setQuery(query);
+    }
+
+    kLogger.debug() << "Sending request to:" << url.toString(QUrl::RemoveQuery);
+
+    QNetworkReply* reply = m_pNetworkManager->get(QNetworkRequest(url));
+    connect(reply, &QNetworkReply::finished, this, [this, reply, endpoint]() {
+        handleResponse(reply, endpoint);
+    });
+}
+
+void OpenSubSonicApiClient::handleResponse(
+        QNetworkReply* reply, const QString& endpoint) {
+    reply->deleteLater();
+
+    if (reply->error() != QNetworkReply::NoError) {
+        const QString errorMsg = reply->errorString();
+        kLogger.warning() << "Network error for" << endpoint << ":" << errorMsg;
+        if (endpoint == QStringLiteral("ping")) {
+            emit pingFailed(errorMsg);
+        }
+        emit requestFailed(endpoint, errorMsg);
+        return;
+    }
+
+    const QByteArray data = reply->readAll();
+    QJsonParseError parseError;
+    const QJsonDocument doc = QJsonDocument::fromJson(data, &parseError);
+
+    if (parseError.error != QJsonParseError::NoError) {
+        const QString errorMsg = QStringLiteral("JSON parse error: ") + parseError.errorString();
+        kLogger.warning() << errorMsg;
+        if (endpoint == QStringLiteral("ping")) {
+            emit pingFailed(errorMsg);
+        }
+        emit requestFailed(endpoint, errorMsg);
+        return;
+    }
+
+    const QJsonObject root = doc.object();
+    const QJsonObject response = root.value(QStringLiteral("subsonic-response")).toObject();
+
+    const QString status = response.value(QStringLiteral("status")).toString();
+    if (status != QStringLiteral("ok")) {
+        const QJsonObject error = response.value(QStringLiteral("error")).toObject();
+        const QString errorMsg = error.value(QStringLiteral("message")).toString(
+                QStringLiteral("Unknown server error"));
+        kLogger.warning() << "Server error for" << endpoint << ":" << errorMsg;
+        if (endpoint == QStringLiteral("ping")) {
+            emit pingFailed(errorMsg);
+        }
+        emit requestFailed(endpoint, errorMsg);
+        return;
+    }
+
+    if (endpoint == QStringLiteral("ping")) {
+        emit pingSucceeded();
+    } else if (endpoint == QStringLiteral("getArtists")) {
+        const QJsonObject artists = response.value(QStringLiteral("artists")).toObject();
+        emit artistsLoaded(artists.value(QStringLiteral("index")).toArray());
+    } else if (endpoint == QStringLiteral("getArtist")) {
+        emit artistLoaded(response.value(QStringLiteral("artist")).toObject());
+    } else if (endpoint == QStringLiteral("getAlbum")) {
+        emit albumLoaded(response.value(QStringLiteral("album")).toObject());
+    } else if (endpoint == QStringLiteral("getSong")) {
+        emit songLoaded(response.value(QStringLiteral("song")).toObject());
+    } else if (endpoint == QStringLiteral("search3")) {
+        emit searchResultsLoaded(response.value(QStringLiteral("searchResult3")).toObject());
+    } else if (endpoint == QStringLiteral("getGenres")) {
+        const QJsonObject genres = response.value(QStringLiteral("genres")).toObject();
+        emit genresLoaded(genres.value(QStringLiteral("genre")).toArray());
+    } else if (endpoint == QStringLiteral("getPlaylists")) {
+        const QJsonObject playlists = response.value(QStringLiteral("playlists")).toObject();
+        emit playlistsLoaded(playlists.value(QStringLiteral("playlist")).toArray());
+    } else if (endpoint == QStringLiteral("getPlaylist")) {
+        emit playlistLoaded(response.value(QStringLiteral("playlist")).toObject());
+    } else if (endpoint == QStringLiteral("getOpenSubsonicExtensions")) {
+        emit extensionsLoaded(
+                response.value(QStringLiteral("openSubsonicExtensions")).toArray());
+    }
+}
+
+void OpenSubSonicApiClient::ping() {
+    sendRequest(QStringLiteral("ping"));
+}
+
+void OpenSubSonicApiClient::getArtists() {
+    sendRequest(QStringLiteral("getArtists"));
+}
+
+void OpenSubSonicApiClient::getArtist(const QString& id) {
+    QUrlQuery params;
+    params.addQueryItem(QStringLiteral("id"), id);
+    sendRequest(QStringLiteral("getArtist"), params);
+}
+
+void OpenSubSonicApiClient::getAlbum(const QString& id) {
+    QUrlQuery params;
+    params.addQueryItem(QStringLiteral("id"), id);
+    sendRequest(QStringLiteral("getAlbum"), params);
+}
+
+void OpenSubSonicApiClient::getSong(const QString& id) {
+    QUrlQuery params;
+    params.addQueryItem(QStringLiteral("id"), id);
+    sendRequest(QStringLiteral("getSong"), params);
+}
+
+void OpenSubSonicApiClient::search3(const QString& query,
+        int artistCount, int albumCount, int songCount) {
+    QUrlQuery params;
+    params.addQueryItem(QStringLiteral("query"), query);
+    params.addQueryItem(QStringLiteral("artistCount"), QString::number(artistCount));
+    params.addQueryItem(QStringLiteral("albumCount"), QString::number(albumCount));
+    params.addQueryItem(QStringLiteral("songCount"), QString::number(songCount));
+    sendRequest(QStringLiteral("search3"), params);
+}
+
+void OpenSubSonicApiClient::getGenres() {
+    sendRequest(QStringLiteral("getGenres"));
+}
+
+void OpenSubSonicApiClient::getPlaylists() {
+    sendRequest(QStringLiteral("getPlaylists"));
+}
+
+void OpenSubSonicApiClient::getPlaylist(const QString& id) {
+    QUrlQuery params;
+    params.addQueryItem(QStringLiteral("id"), id);
+    sendRequest(QStringLiteral("getPlaylist"), params);
+}
+
+void OpenSubSonicApiClient::getOpenSubsonicExtensions() {
+    sendRequest(QStringLiteral("getOpenSubsonicExtensions"));
+}
+
+QUrl OpenSubSonicApiClient::streamUrl(const QString& id,
+        int maxBitRate, const QString& format) const {
+    QUrl url = m_config.serverUrl;
+    QString path = normalizedPath(url);
+    path.append(QStringLiteral("/rest/stream"));
+    url.setPath(path);
+
+    QUrlQuery query;
+    query.addQueryItem(QStringLiteral("u"), m_config.username);
+    query.addQueryItem(QStringLiteral("v"), m_config.apiVersion);
+    query.addQueryItem(QStringLiteral("c"), m_config.clientName);
+    query.addQueryItem(QStringLiteral("f"), QStringLiteral("json"));
+
+    const auto [token, salt] = generateDeterministicAuthToken();
+    query.addQueryItem(QStringLiteral("t"), token);
+    query.addQueryItem(QStringLiteral("s"), salt);
+
+    query.addQueryItem(QStringLiteral("id"), id);
+    if (maxBitRate > 0) {
+        query.addQueryItem(QStringLiteral("maxBitRate"), QString::number(maxBitRate));
+    }
+    if (!format.isEmpty()) {
+        query.addQueryItem(QStringLiteral("format"), format);
+    }
+    url.setQuery(query);
+    return url;
+}
+
+} // namespace opensubsonic
+} // namespace library
+} // namespace mixxx
diff --git a/src/library/opensubsonic/opensubsonicapiclient.h b/src/library/opensubsonic/opensubsonicapiclient.h
new file mode 100644
index 0000000..0f5ceba
--- /dev/null
+++ b/src/library/opensubsonic/opensubsonicapiclient.h
@@ -0,0 +1,95 @@
+#pragma once
+
+#include <QJsonArray>
+#include <QJsonObject>
+#include <QNetworkAccessManager>
+#include <QObject>
+#include <QString>
+#include <QUrl>
+#include <QUrlQuery>
+
+#include "preferences/usersettings.h"
+
+namespace mixxx {
+namespace library {
+namespace opensubsonic {
+
+struct ServerConfig {
+    QUrl serverUrl;
+    QString username;
+    QString password;
+    QString clientName = QStringLiteral("Mixxx");
+    QString apiVersion = QStringLiteral("1.16.1");
+
+    bool isValid() const {
+        return serverUrl.isValid() && !username.isEmpty() && !password.isEmpty();
+    }
+};
+
+class OpenSubSonicApiClient : public QObject {
+    Q_OBJECT
+
+  public:
+    explicit OpenSubSonicApiClient(
+            QNetworkAccessManager* pNetworkManager,
+            const ServerConfig& config,
+            QObject* parent = nullptr);
+    ~OpenSubSonicApiClient() override = default;
+
+    void ping();
+
+    void getArtists();
+    void getArtist(const QString& id);
+    void getAlbum(const QString& id);
+    void getSong(const QString& id);
+    void search3(const QString& query, int artistCount = 20,
+            int albumCount = 20, int songCount = 20);
+    void getGenres();
+
+    void getPlaylists();
+    void getPlaylist(const QString& id);
+
+    QUrl streamUrl(const QString& id, int maxBitRate = 0,
+            const QString& format = QString()) const;
+
+    void getOpenSubsonicExtensions();
+
+    void setServerConfig(const ServerConfig& config);
+    const ServerConfig& serverConfig() const {
+        return m_config;
+    }
+
+  signals:
+    void pingSucceeded();
+    void pingFailed(const QString& errorMessage);
+
+    void artistsLoaded(const QJsonArray& artists);
+    void artistLoaded(const QJsonObject& artist);
+    void albumLoaded(const QJsonObject& album);
+    void songLoaded(const QJsonObject& song);
+    void searchResultsLoaded(const QJsonObject& results);
+    void genresLoaded(const QJsonArray& genres);
+
+    void playlistsLoaded(const QJsonArray& playlists);
+    void playlistLoaded(const QJsonObject& playlist);
+
+    void extensionsLoaded(const QJsonArray& extensions);
+
+    void requestFailed(const QString& endpoint, const QString& errorMessage);
+
+  private:
+    QUrl buildRequestUrl(const QString& endpoint) const;
+    QUrlQuery buildAuthQuery() const;
+    QPair<QString, QString> generateAuthToken() const;
+    QPair<QString, QString> generateDeterministicAuthToken() const;
+    void sendRequest(const QString& endpoint, const QUrlQuery& extraParams = QUrlQuery());
+    void handleResponse(QNetworkReply* reply, const QString& endpoint);
+    static QString normalizedPath(const QUrl& serverUrl);
+
+    QNetworkAccessManager* m_pNetworkManager;
+    ServerConfig m_config;
+};
+
+} // namespace opensubsonic
+} // namespace library
+} // namespace mixxx
diff --git a/src/library/opensubsonic/opensubsonicfeature.cpp b/src/library/opensubsonic/opensubsonicfeature.cpp
