diff --git a/src/library/opensubsonic/opensubsonictrackmodel.cpp b/src/library/opensubsonic/opensubsonictrackmodel.cpp
new file mode 100644
index 0000000..adef5c1
--- /dev/null
+++ b/src/library/opensubsonic/opensubsonictrackmodel.cpp
@@ -0,0 +1,98 @@
+#include "library/opensubsonic/opensubsonictrackmodel.h"
+
+#include <QDir>
+#include <QEventLoop>
+#include <QFileInfo>
+#include <QNetworkReply>
+#include <QNetworkRequest>
+
+#include "moc_opensubsonictrackmodel.cpp"
+#include "util/logger.h"
+
+namespace {
+const mixxx::Logger kLogger("OpenSubSonicTrackModel");
+} // anonymous namespace
+
+OpenSubSonicTrackModel::OpenSubSonicTrackModel(QObject* parent,
+        TrackCollectionManager* pTrackCollectionManager,
+        const char* settingsNamespace,
+        const QString& trackTable,
+        QSharedPointer<BaseTrackCache> trackSource,
+        QNetworkAccessManager* pNetworkManager,
+        mixxx::library::opensubsonic::OpenSubSonicApiClient* pApiClient)
+        : BaseExternalTrackModel(parent,
+                  pTrackCollectionManager,
+                  settingsNamespace,
+                  trackTable,
+                  std::move(trackSource)),
+          m_pNetworkManager(pNetworkManager),
+          m_pApiClient(pApiClient) {
+}
+
+TrackPointer OpenSubSonicTrackModel::getTrack(const QModelIndex& index) const {
+    QString nativeLocation = getFieldString(
+            index, ColumnCache::COLUMN_TRACKLOCATIONSTABLE_LOCATION);
+    QString location = QDir::fromNativeSeparators(nativeLocation);
+
+    if (location.isEmpty()) {
+        return TrackPointer();
+    }
+
+    // If the file doesn't exist locally, download from server
+    if (!QFileInfo::exists(location)) {
+        if (!ensureCached(location)) {
+            kLogger.warning() << "Failed to download track to cache:" << location;
+            return TrackPointer();
+        }
+    }
+
+    // Delegate to base class which uses TrackRef::fromFilePath
+    return BaseExternalTrackModel::getTrack(index);
+}
+
+bool OpenSubSonicTrackModel::ensureCached(const QString& location) const {
+    if (!m_pApiClient || !m_pNetworkManager) {
+        return false;
+    }
+
+    // Extract song ID from cache path: .../opensubsonic/<songId>.<ext>
+    const QString songId = QFileInfo(location).completeBaseName();
+    if (songId.isEmpty()) {
+        return false;
+    }
+
+    const QUrl streamUrl = m_pApiClient->streamUrl(songId);
+    if (!streamUrl.isValid()) {
+        return false;
+    }
+
+    // Ensure cache directory exists
+    QDir().mkpath(QFileInfo(location).absolutePath());
+
+    // Synchronous download using QEventLoop
+    QNetworkRequest request(streamUrl);
+    QNetworkReply* pReply = m_pNetworkManager->get(request);
+
+    QEventLoop loop;
+    QObject::connect(pReply, &QNetworkReply::finished, &loop, &QEventLoop::quit);
+    loop.exec();
+
+    if (pReply->error() != QNetworkReply::NoError) {
+        kLogger.warning() << "Download failed:" << pReply->errorString();
+        pReply->deleteLater();
+        return false;
+    }
+
+    QFile file(location);
+    if (!file.open(QIODevice::WriteOnly)) {
+        kLogger.warning() << "Failed to open cache file for writing:" << location;
+        pReply->deleteLater();
+        return false;
+    }
+
+    file.write(pReply->readAll());
+    file.close();
+    pReply->deleteLater();
+
+    return QFileInfo::exists(location);
+}
