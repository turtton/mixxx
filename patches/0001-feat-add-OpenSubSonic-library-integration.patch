index 0000000..fa23f79
--- /dev/null
+++ b/src/library/opensubsonic/opensubsonicfeature.cpp
@@ -0,0 +1,552 @@
+#include "library/opensubsonic/opensubsonicfeature.h"
+
+#include <QJsonArray>
+#include <QJsonObject>
+#include <QMessageBox>
+#include <QSqlQuery>
+#include <QStandardPaths>
+
+#include "library/baseexternalplaylistmodel.h"
+#include "library/baseexternaltrackmodel.h"
+#include "library/basetrackcache.h"
+#include "library/library.h"
+#include "library/opensubsonic/opensubsonictrackmodel.h"
+#include "library/queryutil.h"
+#include "library/trackcollection.h"
+#include "library/trackcollectionmanager.h"
+#include "library/treeitem.h"
+#include "library/treeitemmodel.h"
+#include "moc_opensubsonicfeature.cpp"
+#include "util/logger.h"
+
+namespace {
+const mixxx::Logger kLogger("OpenSubSonicFeature");
+const QString kConfigGroup = QStringLiteral("[Library]");
+const QString kTableLibrary = QStringLiteral("opensubsonic_library");
+const QString kTablePlaylists = QStringLiteral("opensubsonic_playlists");
+const QString kTablePlaylistTracks = QStringLiteral("opensubsonic_playlist_tracks");
+
+void createDatabaseTables(QSqlDatabase& database) {
+    QSqlQuery query(database);
+    if (!query.exec(QStringLiteral(
+                "CREATE TABLE IF NOT EXISTS opensubsonic_library ("
+                "    id INTEGER PRIMARY KEY AUTOINCREMENT,"
+                "    artist TEXT,"
+                "    title TEXT,"
+                "    album TEXT,"
+                "    album_artist TEXT,"
+                "    year INTEGER,"
+                "    genre TEXT,"
+                "    tracknumber TEXT,"
+                "    location TEXT,"
+                "    comment TEXT,"
+                "    duration INTEGER,"
+                "    bitrate TEXT,"
+                "    bpm FLOAT,"
+                "    key TEXT,"
+                "    rating INTEGER"
+                ")"))) {
+        kLogger.warning() << "Failed to create library table:" << query.lastError();
+    }
+    if (!query.exec(QStringLiteral(
+                "CREATE TABLE IF NOT EXISTS opensubsonic_playlists ("
+                "    id INTEGER PRIMARY KEY,"
+                "    name TEXT UNIQUE"
+                ")"))) {
+        kLogger.warning() << "Failed to create playlists table:" << query.lastError();
+    }
+    if (!query.exec(QStringLiteral(
+                "CREATE TABLE IF NOT EXISTS opensubsonic_playlist_tracks ("
+                "    id INTEGER PRIMARY KEY AUTOINCREMENT,"
+                "    playlist_id INTEGER REFERENCES opensubsonic_playlists(id),"
+                "    track_id INTEGER REFERENCES opensubsonic_library(id),"
+                "    position INTEGER"
+                ")"))) {
+        kLogger.warning() << "Failed to create playlist_tracks table:" << query.lastError();
+    }
+}
+
+void clearTable(QSqlDatabase& database, const QString& tableName) {
+    QSqlQuery query(database);
+    if (!query.exec(QStringLiteral("DELETE FROM ") + tableName)) {
+        kLogger.warning() << "Failed to clear table" << tableName << ":" << query.lastError();
+    }
+}
+
+} // anonymous namespace
+
+OpenSubSonicFeature::OpenSubSonicFeature(Library* pLibrary, UserSettingsPointer pConfig)
+        : BaseExternalLibraryFeature(pLibrary, pConfig, QStringLiteral("opensubsonic")),
+          m_pSidebarModel(make_parented<TreeItemModel>(this)),
+          m_pTrackModel(nullptr),
+          m_pPlaylistModel(nullptr),
+          m_isActivated(false),
+          m_pendingArtistAlbumLoads(0) {
+    QString tableName = kTableLibrary;
+    QString idColumn = QStringLiteral("id");
+    QStringList columns = {
+            QStringLiteral("id"),
+            QStringLiteral("artist"),
+            QStringLiteral("title"),
+            QStringLiteral("album"),
+            QStringLiteral("album_artist"),
+            QStringLiteral("year"),
+            QStringLiteral("genre"),
+            QStringLiteral("tracknumber"),
+            QStringLiteral("location"),
+            QStringLiteral("comment"),
+            QStringLiteral("duration"),
+            QStringLiteral("bitrate"),
+            QStringLiteral("bpm"),
+            QStringLiteral("key"),
+            QStringLiteral("rating")};
+    QStringList searchColumns = {
+            QStringLiteral("artist"),
+            QStringLiteral("album"),
+            QStringLiteral("album_artist"),
+            QStringLiteral("title"),
+            QStringLiteral("genre"),
+            QStringLiteral("comment")};
+
+    m_trackSource = QSharedPointer<BaseTrackCache>::create(
+            m_pLibrary->trackCollectionManager()->internalCollection(),
+            std::move(tableName),
+            std::move(idColumn),
+            std::move(columns),
+            std::move(searchColumns),
+            false);
+
+    m_pTrackModel = new OpenSubSonicTrackModel(this,
+            m_pLibrary->trackCollectionManager(),
+            "mixxx.db.model.opensubsonic",
+            kTableLibrary,
+            m_trackSource,
+            nullptr,
+            nullptr);
+    m_pPlaylistModel = new BaseExternalPlaylistModel(this,
+            m_pLibrary->trackCollectionManager(),
+            "mixxx.db.model.opensubsonic_playlist",
+            kTablePlaylists,
+            kTablePlaylistTracks,
+            m_trackSource);
+
+    m_database = QSqlDatabase::cloneDatabase(
+            m_pLibrary->trackCollectionManager()
+                    ->internalCollection()
+                    ->database(),
+            QStringLiteral("OPENSUBSONIC_SCANNER"));
+
+    if (!m_database.open()) {
+        kLogger.warning() << "Failed to open database for OpenSubSonic scanner."
+                          << m_database.lastError();
+    }
+
+    createDatabaseTables(m_database);
+    m_pTrackModel->setSearch("");
+}
+
+OpenSubSonicFeature::~OpenSubSonicFeature() {
+    m_database.close();
+    delete m_pTrackModel;
+    delete m_pPlaylistModel;
+}
+
+bool OpenSubSonicFeature::isSupported() {
+    return true;
+}
+
+QVariant OpenSubSonicFeature::title() {
+    return QVariant(QStringLiteral("OpenSubSonic"));
+}
+
+TreeItemModel* OpenSubSonicFeature::sidebarModel() const {
+    return m_pSidebarModel;
+}
+
+void OpenSubSonicFeature::bindSidebarWidget(WLibrarySidebar* pSidebarWidget) {
+    BaseExternalLibraryFeature::bindSidebarWidget(pSidebarWidget);
+}
+
+void OpenSubSonicFeature::activate() {
+    if (!m_isActivated) {
+        connectToServer();
+    }
+    emit showTrackModel(m_pTrackModel);
+    emit enableCoverArtDisplay(false);
+}
+
+void OpenSubSonicFeature::activateChild(const QModelIndex& index) {
+    TreeItem* treeItem = static_cast<TreeItem*>(index.internalPointer());
+    if (!treeItem) {
+        return;
+    }
+
+    m_pendingArtistAlbumLoads = 0;
+
+    const QString dataStr = treeItem->getData().toString();
+    if (dataStr.startsWith(QStringLiteral("artist:"))) {
+        const QString artistId = dataStr.mid(7);
+        m_activeViewType = QStringLiteral("artist");
+        m_activeViewId = artistId;
+        m_pApiClient->getArtist(artistId);
+    } else if (dataStr.startsWith(QStringLiteral("playlist:"))) {
+        const QString playlistId = dataStr.mid(9);
+        m_activeViewType = QStringLiteral("playlist");
+        m_activeViewId = playlistId;
+        m_pApiClient->getPlaylist(playlistId);
+    } else if (dataStr.startsWith(QStringLiteral("album:"))) {
+        const QString albumId = dataStr.mid(6);
+        m_activeViewType = QStringLiteral("album");
+        m_activeViewId = albumId;
+        m_pApiClient->getAlbum(albumId);
+    } else {
+        m_activeViewType.clear();
+        m_activeViewId.clear();
+        emit showTrackModel(m_pTrackModel);
+    }
+    emit enableCoverArtDisplay(false);
+}
+
+void OpenSubSonicFeature::onRightClick(const QPoint& globalPos) {
+    BaseExternalLibraryFeature::onRightClick(globalPos);
+}
+
+void OpenSubSonicFeature::connectToServer() {
+    using namespace mixxx::library::opensubsonic;
+
+    ServerConfig config;
+    config.serverUrl = QUrl(m_pConfig->getValueString(
+            ConfigKey(kConfigGroup, QStringLiteral("OpenSubSonicServerUrl"))));
+    config.username = m_pConfig->getValueString(
+            ConfigKey(kConfigGroup, QStringLiteral("OpenSubSonicUsername")));
+    config.password = m_pConfig->getValueString(
+            ConfigKey(kConfigGroup, QStringLiteral("OpenSubSonicPassword")));
+
+    if (!config.isValid()) {
+        kLogger.info() << "OpenSubSonic server not configured.";
+        return;
+    }
+
+    m_pNetworkManager = std::make_unique<QNetworkAccessManager>();
+    m_pApiClient = std::make_unique<OpenSubSonicApiClient>(
+            m_pNetworkManager.get(), config, this);
+
+    m_pTrackModel->setNetworkManager(m_pNetworkManager.get());
+    m_pTrackModel->setApiClient(m_pApiClient.get());
+
+    connect(m_pApiClient.get(),
+            &OpenSubSonicApiClient::pingSucceeded,
+            this,
+            &OpenSubSonicFeature::slotPingSucceeded);
+    connect(m_pApiClient.get(),
+            &OpenSubSonicApiClient::pingFailed,
+            this,
+            &OpenSubSonicFeature::slotPingFailed);
+    connect(m_pApiClient.get(),
+            &OpenSubSonicApiClient::artistsLoaded,
+            this,
+            &OpenSubSonicFeature::slotArtistsLoaded);
+    connect(m_pApiClient.get(),
+            &OpenSubSonicApiClient::artistLoaded,
+            this,
+            &OpenSubSonicFeature::slotArtistLoaded);
+    connect(m_pApiClient.get(),
+            &OpenSubSonicApiClient::albumLoaded,
+            this,
+            &OpenSubSonicFeature::slotAlbumLoaded);
+    connect(m_pApiClient.get(),
+            &OpenSubSonicApiClient::playlistsLoaded,
+            this,
+            &OpenSubSonicFeature::slotPlaylistsLoaded);
+    connect(m_pApiClient.get(),
+            &OpenSubSonicApiClient::playlistLoaded,
+            this,
+            &OpenSubSonicFeature::slotPlaylistLoaded);
+
+    m_pApiClient->ping();
+}
+
+void OpenSubSonicFeature::slotPingSucceeded() {
+    kLogger.info() << "Connected to OpenSubSonic server.";
+    m_isActivated = true;
+    m_pApiClient->getArtists();
+    m_pApiClient->getPlaylists();
+}
